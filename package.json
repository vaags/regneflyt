{
	"name": "regneflyt",
	"version": "2.12.2",
	"scripts": {
		"dev": "vite dev",
		"prepare:codegen": "svelte-kit sync && npx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"build": "npm run prepare:codegen && vite build",
		"build:only": "vite build",
		"preview": "vite preview",
		"test": "npm run test:unit && npm run test:e2e",
		"test:all": "npm run test:unit:coverage && npm run test:e2e && node scripts/bundle-budget.mjs && node scripts/perf-check.mjs",
		"test:quick": "npm run test:unit && npm run test:e2e",
		"test:unit": "vitest run",
		"test:unit:coverage": "vitest run --coverage",
		"test:unit:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:a11y": "playwright test tests/e2e/accessibility.spec.ts",
		"test:bundle": "npm run build && node scripts/bundle-budget.mjs",
		"test:perf": "npm run build && node scripts/perf-check.mjs",
		"deploy:check": "npm run prepare:codegen && npm run test:unit:coverage && npm run build:only",
		"check": "npm run prepare:codegen && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run prepare:codegen && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.2.1",
		"@testing-library/svelte": "^5.3.1",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"@vitest/coverage-v8": "^4.1.0",
		"chrome-launcher": "^1.2.1",
		"cssnano": "^7.1.3",
		"eslint": "^10.0.3",
		"eslint-plugin-svelte": "^3.15.2",
		"jsdom": "^29.0.0",
		"lighthouse": "^13.0.3",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"svelte-eslint-parser": "^1.6.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.0"
	},
	"type": "module",
	"dependencies": {
		"@inlang/paraglide-js": "^2.15.0",
		"@vercel/speed-insights": "^2.0.0",
		"pure-rand": "^8.0.0"
	}
}
