{
    "hooks": {
        "PreToolUse": [
            {
                "type": "command",
                "command": "node ./scripts/hooks/copilot-policy.mjs pre-tool",
                "timeout": 10
            }
        ],
        "PostToolUse": [
            {
                "type": "command",
                "command": "node ./scripts/hooks/copilot-policy.mjs post-tool",
                "timeout": 10
            }
        ],
        "Stop": [
            {
                "type": "command",
                "command": "node ./scripts/hooks/copilot-policy.mjs stop",
                "timeout": 10
            }
        ]
    }
}
